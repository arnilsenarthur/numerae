# Database (Neon/Vercel Postgres — free tier)
DATABASE_URL="postgresql://USER:PASSWORD@HOST/numerae?sslmode=require"

# Auth.js — gere com: openssl rand -base64 32
AUTH_SECRET="change-me-to-a-long-random-string"
AUTH_URL="http://localhost:3000"

# E-mail — Gmail SMTP (grátis, ~500 e-mails/dia, envia para qualquer destinatário)
# Use SENHA DE APP do Google (não a senha normal da conta)
SMTP_USER="seu@gmail.com"
SMTP_PASS="xxxx xxxx xxxx xxxx"
EMAIL_FROM="Numerae <seu@gmail.com>"
# SMTP_HOST="smtp.gmail.com"   # opcional — detectado automaticamente para @gmail.com
# SMTP_PORT="587"

# Alternativa: Resend (requer domínio verificado; ignorado se SMTP_USER estiver definido)
# RESEND_API_KEY=""
# EMAIL_MODE="test"

# Opcional: e-mail que recebe role ADMIN no cadastro
ADMIN_EMAIL=""

# Workers / câmbio — Open Exchange Rates (fallback opcional)
EXCHANGE_RATES_API_KEY=""

# Cron protegido — POST /api/cron/workers
CRON_SECRET=""
