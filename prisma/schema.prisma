generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  USER
  ADMIN
}

enum AdminAuditAction {
  CREATE
  UPDATE
  DELETE
}

enum InstitutionType {
  BANK
  FINTECH
  BROKER
  REMITTANCE
  EXCHANGE
  OTHER
}

enum InstitutionProductKind {
  CHECKING
  SAVINGS
  INVESTMENT
  CREDIT
  PAYMENT
  OTHER
}

enum WorkerRunStatus {
  SUCCESS
  PARTIAL
  FAILED
  SKIPPED
}

enum WorkerRunTrigger {
  MANUAL
  CRON
  SYSTEM
}

model User {
  id            String     @id @default(cuid())
  name          String?
  email         String     @unique
  emailVerified DateTime?
  passwordHash  String
  role          UserRole   @default(USER)
  active        Boolean    @default(true)
  countryCode   String     @default("BR")
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  companies     UserCompany[]
  auditLogs     AdminAuditLog[]
  accounts      FinancialAccount[]
  transactions  Transaction[]
  investmentPlans     InvestmentPlan[]
  investmentPositions InvestmentPosition[]
  recurringTransactions RecurringTransaction[]
  goals         FinancialGoal[]
  budgets       Budget[]
  preference    UserPreference?
}

model FinancialGoal {
  id            String    @id @default(cuid())
  userId        String
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  title         String
  targetAmount  Decimal   @db.Decimal(18, 2)
  currentAmount Decimal   @default(0) @db.Decimal(18, 2)
  currency      String    @default("BRL") @db.VarChar(8)
  deadline      DateTime?
  category      String    @default("other")
  notes         String?
  icon          String?
  achieved      Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([userId, achieved])
}

enum CompanyRegistrationKind {
  CNPJ
  EIN
  VAT_ID
  COMPANY_NUMBER
  OTHER
}

model UserCompany {
  id                  String                  @id @default(cuid())
  userId              String
  user                User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  countryCode         String                  @default("BR") @db.Char(2)
  label               String
  legalName           String?
  registrationId      String
  registrationKind    CompanyRegistrationKind @default(CNPJ)
  activityCode        String?
  activityDescription String?
  taxRegime           String                  @default("simples")
  taxRate             Decimal                 @db.Decimal(5, 2)
  isDefault           Boolean                 @default(false)
  createdAt           DateTime                @default(now())
  updatedAt           DateTime                @updatedAt

  @@unique([userId, countryCode, registrationId])
  @@index([userId])
}

model EmailVerification {
  id        String   @id @default(cuid())
  email     String
  code      String
  expires   DateTime
  createdAt DateTime @default(now())

  @@index([email])
}

model PasswordReset {
  id        String   @id @default(cuid())
  email     String
  code      String
  expires   DateTime
  createdAt DateTime @default(now())

  @@index([email])
}

model Country {
  code          String        @id @db.Char(2)
  name          String
  active        Boolean       @default(true)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  currencies    Currency[]
  institutions  Institution[]

  @@index([active])
}

model Currency {
  id                String    @id @default(cuid())
  code              String    @db.VarChar(8)
  name              String
  countryCode       String    @db.Char(2)
  country           Country   @relation(fields: [countryCode], references: [code])
  symbol            String?
  usdRate           Decimal?  @db.Decimal(18, 8)
  usdRateUpdatedAt  DateTime?
  usdRateTtlSeconds Int       @default(3600)
  active            Boolean   @default(true)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  quotes            CurrencyQuote[]

  @@unique([code, countryCode])
  @@index([countryCode])
}

model CurrencyQuote {
  id         String   @id @default(cuid())
  currencyId String
  currency   Currency @relation(fields: [currencyId], references: [id], onDelete: Cascade)
  usdRate    Decimal  @db.Decimal(18, 8)
  quotedAt   DateTime
  createdAt  DateTime @default(now())

  @@unique([currencyId, quotedAt])
  @@index([currencyId, quotedAt])
}

model Institution {
  id            String                  @id @default(cuid())
  slug          String                  @unique
  name          String
  type          InstitutionType         @default(OTHER)
  countryCode   String                  @db.Char(2)
  country       Country                 @relation(fields: [countryCode], references: [code])
  website       String?
  logoUrl       String?
  brandColor    String?
  description   String?
  active        Boolean                 @default(true)
  createdAt     DateTime                @default(now())
  updatedAt     DateTime                @updatedAt
  exchangeRates InstitutionExchangeRate[]
  products      InstitutionProduct[]
  accounts      FinancialAccount[]

  @@index([type])
  @@index([countryCode])
}

model InstitutionProduct {
  id                 String                 @id @default(cuid())
  institutionId      String
  institution        Institution            @relation(fields: [institutionId], references: [id], onDelete: Cascade)
  name               String
  slug               String
  kind               InstitutionProductKind @default(OTHER)
  currencyCode       String?                @db.VarChar(8)
  description        String?
  annualRatePercent  Decimal?               @db.Decimal(8, 4)
  riskLevel          String?
  active             Boolean                @default(true)
  createdAt          DateTime               @default(now())
  updatedAt          DateTime               @updatedAt

  @@unique([institutionId, slug])
  @@index([institutionId])
}

model AdminAuditLog {
  id          String           @id @default(cuid())
  userId      String
  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  action      AdminAuditAction
  entityType  String
  entityId    String
  entityLabel String?
  parentType  String?
  parentId    String?
  before      Json?
  after       Json?
  createdAt   DateTime         @default(now())

  @@index([userId])
  @@index([entityType, entityId])
  @@index([parentType, parentId])
  @@index([createdAt])
}

model InstitutionExchangeRate {
  id                String      @id @default(cuid())
  institutionId     String
  institution       Institution @relation(fields: [institutionId], references: [id], onDelete: Cascade)
  fromCurrency      String      @db.VarChar(8)
  toCurrency        String      @db.VarChar(8)
  rate              Decimal     @db.Decimal(18, 8)
  rateUpdatedAt     DateTime?
  rateTtlSeconds    Int         @default(3600)
  spreadPercent     Decimal     @default(0) @db.Decimal(8, 4)
  spreadUpdatedAt   DateTime?
  spreadTtlSeconds  Int         @default(3600)
  feeFixed          Decimal?    @db.Decimal(12, 2)
  feePercent        Decimal?    @db.Decimal(8, 4)
  notes             String?
  active            Boolean     @default(true)
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  @@unique([institutionId, fromCurrency, toCurrency])
  @@index([institutionId])
}

model Worker {
  id                String           @id
  name              String
  description       String?
  enabled           Boolean          @default(true)
  primaryProvider   String           @default("frankfurter")
  secondaryProvider String?
  intervalSeconds   Int              @default(3600)
  historyLookbackDays Int?
  lastRunAt         DateTime?
  runningSince      DateTime?
  lastRunStatus     WorkerRunStatus?
  lastRunProvider   String?
  lastRunError      String?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  runs              WorkerRun[]

  @@index([enabled])
  @@index([runningSince])
}

model WorkerRun {
  id                 String            @id @default(cuid())
  workerId           String
  worker             Worker            @relation(fields: [workerId], references: [id], onDelete: Cascade)
  status             WorkerRunStatus
  trigger            WorkerRunTrigger
  provider           String?
  fallbackUsed       Boolean           @default(false)
  attemptedProviders Json?
  durationMs         Int?
  summary            Json?
  error              String?
  createdAt          DateTime          @default(now())

  @@index([workerId, createdAt])
  @@index([createdAt])
}

// ── Controle financeiro (contas + lançamentos) ──────────────────────

enum FinancialAccountKind {
  CHECKING
  SAVINGS
  INVESTMENT
  CREDIT_CARD
  CASH
  OTHER
}

model FinancialAccount {
  id            String               @id @default(cuid())
  userId        String
  user          User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  institutionId String?
  institution   Institution?         @relation(fields: [institutionId], references: [id], onDelete: SetNull)
  name          String
  kind          FinancialAccountKind @default(CHECKING)
  currencyCode  String               @db.VarChar(8)
  countryCode   String               @default("BR") @db.Char(2)
  initialBalance Decimal             @default(0) @db.Decimal(18, 2)
  creditLimit   Decimal?             @db.Decimal(18, 2)
  color         String?
  icon          String?
  archived      Boolean              @default(false)
  isDefault     Boolean              @default(false)
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt
  transactions  Transaction[]
  recurringTransactions RecurringTransaction[] @relation("RecurringTransactionAccount")
  counterRecurring      RecurringTransaction[] @relation("RecurringTransferCounterAccount")

  @@index([userId, archived])
}

enum TransactionKind {
  INCOME
  EXPENSE
  TRANSFER
}

model Transaction {
  id                String                @id @default(cuid())
  userId            String
  user              User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  accountId         String
  account           FinancialAccount      @relation(fields: [accountId], references: [id], onDelete: Cascade)
  kind              TransactionKind
  amount            Decimal               @db.Decimal(18, 2)
  currencyCode      String                @db.VarChar(8)
  category          String                @default("other")
  description       String
  icon              String?
  date              DateTime
  counterAccountId  String?
  counterAmount     Decimal?              @db.Decimal(18, 2)
  planEntryId       String?
  recurringId       String?
  recurring         RecurringTransaction? @relation(fields: [recurringId], references: [id], onDelete: SetNull)
  notes             String?
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt

  @@index([userId, date])
  @@index([accountId, date])
  @@index([userId, category])
  @@index([recurringId])
  @@unique([recurringId, date])
}

enum RecurrenceType {
  DAILY
  WEEKLY
  BIWEEKLY
  MONTHLY
  BIMONTHLY
  QUARTERLY
  YEARLY
}

model RecurringTransaction {
  id               String           @id @default(cuid())
  userId           String
  user             User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  accountId        String
  account          FinancialAccount @relation("RecurringTransactionAccount", fields: [accountId], references: [id], onDelete: Cascade)
  kind             TransactionKind
  amount           Decimal          @db.Decimal(18, 2)
  currencyCode     String           @db.VarChar(8)
  category         String           @default("other")
  description      String
  icon             String?
  recurrence       RecurrenceType
  // para MONTHLY: dia do mês (1-28); para WEEKLY: dia da semana (0=dom..6=sáb)
  dayOfPeriod      Int              @default(1)
  nextDueAt        DateTime
  endAt            DateTime?
  active           Boolean          @default(true)
  counterAccountId String?
  counterAccount   FinancialAccount? @relation("RecurringTransferCounterAccount", fields: [counterAccountId], references: [id], onDelete: SetNull)
  counterAmount    Decimal?         @db.Decimal(18, 2)
  notes            String?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  transactions     Transaction[]

  @@index([userId, active])
  @@index([nextDueAt])
}

// ── Posições reais de investimento ─────────────────────────────────

enum InvestmentEntryKind {
  DEPOSIT
  WITHDRAWAL
  BALANCE_UPDATE
}

model InvestmentPosition {
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name           String
  assetSymbol    String?
  category       String   @default("OTHER")
  currencyCode   String   @default("BRL") @db.VarChar(8)
  institution    String?
  color          String?
  currentBalance Decimal  @default(0) @db.Decimal(18, 2)
  archived       Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  entries        InvestmentEntry[]

  @@index([userId, archived])
}

model InvestmentEntry {
  id         String              @id @default(cuid())
  positionId String
  position   InvestmentPosition  @relation(fields: [positionId], references: [id], onDelete: Cascade)
  kind       InvestmentEntryKind
  amount     Decimal             @db.Decimal(18, 2)
  balance    Decimal?            @db.Decimal(18, 2)
  date       DateTime
  notes      String?
  createdAt  DateTime            @default(now())

  @@index([positionId, date])
}

// ── Mercado (ativos e cotações via worker) ──────────────────────────

enum MarketAssetKind {
  STOCK
  ETF
  FII
  CRYPTO
  INDEX
  COMMODITY
}

model MarketAsset {
  id              String          @id @default(cuid())
  symbol          String          @unique
  name            String
  kind            MarketAssetKind @default(STOCK)
  exchange        String?
  currencyCode    String          @default("USD") @db.VarChar(8)
  countryCode     String?         @db.Char(2)
  logoUrl         String?
  active          Boolean         @default(true)
  price           Decimal?        @db.Decimal(18, 6)
  priceUpdatedAt  DateTime?
  priceTtlSeconds Int             @default(3600)
  changePercent   Decimal?        @db.Decimal(10, 4)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  quotes          MarketQuote[]

  @@index([kind, active])
}

model MarketQuote {
  id        String      @id @default(cuid())
  assetId   String
  asset     MarketAsset @relation(fields: [assetId], references: [id], onDelete: Cascade)
  price     Decimal     @db.Decimal(18, 6)
  quotedAt  DateTime
  createdAt DateTime    @default(now())

  @@unique([assetId, quotedAt])
  @@index([assetId, quotedAt])
}

// ── Plano de investimento ───────────────────────────────────────────

model InvestmentPlan {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name            String
  currencyCode    String   @default("BRL") @db.VarChar(8)
  initialAmount   Decimal  @default(0) @db.Decimal(18, 2)
  monthlyDeposit  Decimal  @default(0) @db.Decimal(18, 2)
  horizonMonths   Int      @default(60)
  riskProfile     String   @default("moderate")
  targetAmount    Decimal? @db.Decimal(18, 2)
  active          Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([userId, active])
}

// ── Orçamentos mensais ────────────────────────────────────────────────

model Budget {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  category     String
  amount       Decimal  @db.Decimal(18, 2)
  currencyCode String   @db.VarChar(8)
  month        Int
  year         Int
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([userId, category, currencyCode, month, year])
  @@index([userId, year, month])
}

// ── Preferências de usuário ───────────────────────────────────────────

model UserPreference {
  userId          String   @id
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  showDailyTip    Boolean  @default(true)
  defaultCurrency String   @default("BRL") @db.VarChar(8)
  language        String   @default("pt-BR") @db.VarChar(10)
  updatedAt       DateTime @updatedAt
}

// ── Dicas financeiras (conteúdo editorial) ───────────────────────────

model Tip {
  id          String   @id @default(cuid())
  quote       String
  author      String
  category    String   @default("general")
  locale      String   @default("pt-BR") @db.VarChar(10)
  sourceUrl   String?
  sourceLabel String?
  active      Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([active, locale, sortOrder])
}
